generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  AGENT
}

enum IncidentStatus {
  NEW
  INVESTIGATING
  MITIGATED
  RESOLVED
}

enum IncidentSeverity {
  P1
  P2
  P3
}

enum IncidentChannel {
  EMAIL
  CHAT
  SLACK
  API
  OTHER
}

enum AIIncidentCategory {
  HALLUCINATION
  BIAS
  DATA_DRIFT
  MODEL_DEGRADATION
  PROMPT_INJECTION
  ADVERSARIAL_INPUT
  OUTPUT_FILTER_FAILURE
  LATENCY
  AVAILABILITY
  DATA_PRIVACY
  COMPLIANCE
  OTHER
}

enum EventType {
  CREATED
  NOTE
  STATUS_CHANGED
  OWNER_CHANGED
  TRIAGE_RUN
  CUSTOMER_UPDATE
  REMINDER
}

enum AiProvider {
  OPENAI
  GEMINI
  ANTHROPIC
}

enum WorkflowType {
  INCIDENT_TRIAGE
  CUSTOMER_UPDATE
}

enum ReminderStatus {
  QUEUED
  PROCESSED
  FAILED
}

enum EmailNotificationType {
  REMINDER
  CUSTOMER_UPDATE
  INCIDENT_ALERT
  OWNER_ASSIGNED
  WORKSPACE_INVITE
  AUTH_OTP
  AUTH_RECOVERY
  ONBOARDING_WELCOME
  ONBOARDING_GUIDE
}

enum EmailDeliveryStatus {
  SENT
  FAILED
}

enum WebhookIntegrationType {
  DATADOG
  PAGERDUTY
  SENTRY
  GENERIC
  LANGFUSE
  HELICONE
}

enum AiKeyHealthStatus {
  UNKNOWN
  OK
  FAILED
}

model Workspace {
  id                 String                       @id @default(cuid())
  name               String
  slug               String?                      @unique
  statusPageEnabled  Boolean                      @default(false)
  planTier           String                       @default("pro")
  timezone           String                       @default("UTC")
  slackBotToken      String?
  slackChannelId     String?
  slackTeamId        String?
  stripeCustomerId   String?
  samlEnabled        Boolean                      @default(false)
  samlMetadataUrl    String?
  complianceMode     Boolean                      @default(false)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  users              User[]
  incidents          Incident[]
  aiProviderKeys     AiProviderKey[]
  workflowSettings   WorkflowSetting[]
  reminderJobs       ReminderJobLog[]
  quotas             WorkspaceQuota?
  dailyUsage         WorkspaceDailyUsage[]
  analyticsDaily     IncidentAnalyticsDaily[]
  executiveSnapshot  WorkspaceExecutiveSnapshot?
  apiKeys            WorkspaceApiKey[]
  invites            WorkspaceInvite[]
  statusUpdates      StatusUpdate[]
  webhookIntegrations WorkspaceWebhookIntegration[]
  emailNotifications EmailNotificationLog[]
}

model User {
  id             String          @id @default(cuid())
  workspaceId    String
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stytchUserId   String          @unique
  email          String
  name           String
  phone          String?
  role           Role            @default(AGENT)
  ownedIncidents Incident[]      @relation("IncidentOwner")
  events         IncidentEvent[] @relation("EventActor")
  statusUpdates  StatusUpdate[]
  sentInvites    WorkspaceInvite[] @relation("InviteSender")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([workspaceId, email])
  @@index([workspaceId])
}

model Incident {
  id                   String                  @id @default(cuid())
  workspaceId          String
  workspace            Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title                String
  description          String
  customerName         String?
  customerEmail        String?
  channel              IncidentChannel         @default(EMAIL)
  status               IncidentStatus          @default(NEW)
  severity             IncidentSeverity        @default(P3)
  category             AIIncidentCategory?
  ownerUserId          String?
  owner                User?                   @relation("IncidentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  modelVersion         String?
  sourceTicketRef      String?
  summary              String?
  triagedAt            DateTime?
  resolvedAt           DateTime?
  triageRunCount       Int                     @default(0)
  customerUpdateCount  Int                     @default(0)
  remindersSentCount   Int                     @default(0)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  lastCustomerUpdateAt DateTime?
  events               IncidentEvent[]
  reminderJobs         ReminderJobLog[]
  emailNotifications   EmailNotificationLog[]
  statusUpdates        StatusUpdate[]

  @@index([workspaceId, status])
  @@index([workspaceId, severity])
  @@index([workspaceId, category])
  @@index([ownerUserId])
  @@index([workspaceId, updatedAt])
}

model IncidentEvent {
  id           String    @id @default(cuid())
  incidentId   String
  incident     Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actorUserId  String?
  actor        User?     @relation("EventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  eventType    EventType
  body         String
  metadataJson String?
  createdAt    DateTime  @default(now())

  @@index([incidentId, createdAt])
}

model AiProviderKey {
  id                    String          @id @default(cuid())
  workspaceId           String
  workspace             Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider              AiProvider
  encryptedKey          String
  keyLast4              String
  isActive              Boolean         @default(true)
  healthStatus          AiKeyHealthStatus @default(UNKNOWN)
  lastVerifiedAt        DateTime?
  lastVerificationError String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}

model WorkflowSetting {
  id           String       @id @default(cuid())
  workspaceId  String
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflowType WorkflowType
  provider     AiProvider
  model        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([workspaceId, workflowType])
}

model ReminderJobLog {
  id             String         @id @default(cuid())
  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  incidentId     String
  incident       Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  queueMessageId String?
  status         ReminderStatus @default(QUEUED)
  errorMessage   String?
  createdAt      DateTime       @default(now())
  processedAt    DateTime?

  @@index([workspaceId, status])
  @@index([incidentId])
}

model WorkspaceQuota {
  id                    String    @id @default(cuid())
  workspaceId           String    @unique
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  apiRequestsPerMinute  Int       @default(120)
  incidentsPerDay       Int       @default(200)
  triageRunsPerDay      Int       @default(300)
  customerUpdatesPerDay Int       @default(300)
  reminderEmailsPerDay  Int       @default(500)
  reminderIntervalHoursP1 Int     @default(4)
  reminderIntervalHoursP2 Int     @default(24)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model WorkspaceDailyUsage {
  id                  String    @id @default(cuid())
  workspaceId         String
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  usageDate           DateTime  @db.Date
  incidentsCreated    Int       @default(0)
  triageRuns          Int       @default(0)
  customerUpdates     Int       @default(0)
  reminderEmailsSent  Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([workspaceId, usageDate])
  @@index([workspaceId, usageDate])
}

model IncidentAnalyticsDaily {
  id                  String    @id @default(cuid())
  workspaceId         String
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  day                 DateTime  @db.Date
  incidentsCreated    Int       @default(0)
  incidentsResolved   Int       @default(0)
  openAtEndOfDay      Int       @default(0)
  p1Created           Int       @default(0)
  triageRuns          Int       @default(0)
  customerUpdatesSent Int       @default(0)
  reminderEmailsSent  Int       @default(0)
  mttrMinutesAvg      Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([workspaceId, day])
  @@index([workspaceId, day])
}

model WorkspaceExecutiveSnapshot {
  id                         String    @id @default(cuid())
  workspaceId                String    @unique
  workspace                  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  openIncidents              Int       @default(0)
  p1OpenIncidents            Int       @default(0)
  incidentsCreatedLast7d     Int       @default(0)
  incidentsResolvedLast7d    Int       @default(0)
  avgResolutionHoursLast30d  Float     @default(0)
  triageCoveragePct          Float     @default(0)
  customerUpdateCoveragePct  Float     @default(0)
  updatedAt                  DateTime  @updatedAt
}

model EmailNotificationLog {
  id                String               @id @default(cuid())
  workspaceId       String
  workspace         Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  incidentId        String?
  incident          Incident?            @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  type              EmailNotificationType
  toEmail           String
  providerMessageId String?
  status            EmailDeliveryStatus  @default(SENT)
  errorMessage      String?
  createdAt         DateTime             @default(now())

  @@index([workspaceId, createdAt])
  @@index([incidentId])
}

model WorkspaceApiKey {
  id         String    @id @default(cuid())
  workspaceId String
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String
  keyPrefix  String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  isActive   Boolean   @default(true)

  @@unique([keyPrefix])
  @@index([workspaceId, isActive])
}

model WorkspaceInvite {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email           String
  role            Role
  token           String    @unique
  expiresAt       DateTime
  usedAt          DateTime?
  createdByUserId String?
  createdByUser   User?     @relation("InviteSender", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())

  @@index([workspaceId, email])
  @@index([workspaceId, expiresAt])
}

model StatusUpdate {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  incidentId      String
  incident        Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  body            String
  publishedAt     DateTime
  isVisible       Boolean   @default(true)
  createdByUserId String?
  createdByUser   User?     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())

  @@index([workspaceId, publishedAt])
  @@index([incidentId, publishedAt])
}

model WorkspaceWebhookIntegration {
  id              String                 @id @default(cuid())
  workspaceId     String
  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type            WebhookIntegrationType
  encryptedSecret String
  keyLast4        String
  isActive        Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([workspaceId, type])
  @@index([workspaceId, isActive])
}
