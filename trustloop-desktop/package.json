{
  "name": "TrustLoop",
  "productName": "TrustLoop",
  "version": "0.10.0",
  "description": "TrustLoop — Native macOS Desktop App (Apple Silicon)",
  "main": "dist/main/main.js",
  "author": "TrustLoop",
  "license": "PROPRIETARY",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "@prisma/engines",
      "prisma"
    ]
  },
  "scripts": {
    "dev": "pnpm compile && bash scripts/patch-dev-name.sh && NODE_ENV=development pnpm exec electron dist/main/main.js",
    "compile": "pnpm exec tsc -p tsconfig.main.json",
    "build": "pnpm compile && pnpm exec electron-builder --mac --arm64 && bash scripts/compile-icons.sh",
    "pack": "pnpm compile && pnpm exec electron-builder --mac --arm64 --dir",
    "icons": "bash scripts/generate-icns.sh",
    "prisma:generate": "pnpm exec prisma generate --schema=../prisma/schema.prisma"
  },
  "build": {
    "appId": "ai.trustloop.desktop",
    "productName": "TrustLoop",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "CFBundleIconName": "AppIcon"
      }
    },
    "protocols": [
      {
        "name": "TrustLoop OAuth",
        "schemes": [
          "trustloop"
        ]
      }
    ],
    "dmg": {
      "background": "assets/dmg-background@2x.png",
      "icon": "assets/icon.icns",
      "iconSize": 128,
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 180,
          "y": 170
        },
        {
          "x": 480,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "assets/**/*"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1021.0",
    "chart.js": "^4.5.1",
    "dotenv": "^16.5.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "stytch": "^13.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
