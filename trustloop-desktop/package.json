{
  "name": "TrustLoop",
  "productName": "TrustLoop",
  "version": "0.10.0",
  "description": "TrustLoop — Native macOS Desktop App (Apple Silicon)",
  "main": "dist/main/main.js",
  "author": "TrustLoop",
  "license": "PROPRIETARY",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "@prisma/engines",
      "prisma"
    ],
    "overrides": {
      "lodash": ">=4.18.0",
      "effect": ">=3.20.0",
      "hono": ">=4.12.12",
      "@hono/node-server": ">=1.19.13"
    }
  },
  "scripts": {
    "dev": "pnpm compile && bash scripts/patch-dev-name.sh && NODE_ENV=development pnpm exec electron dist/main/main.js",
    "compile": "pnpm exec tsc -p tsconfig.main.json",
    "build": "pnpm prisma:generate && pnpm compile && pnpm exec electron-builder --mac --arm64 && bash scripts/compile-icons.sh",
    "pack": "pnpm prisma:generate && pnpm compile && pnpm exec electron-builder --mac --arm64 --dir",
    "icons": "bash scripts/generate-icns.sh",
    "prisma:generate": "pnpm exec prisma generate --schema=../prisma/schema.prisma && node scripts/link-prisma-client.js"
  },
  "build": {
    "appId": "ai.trustloop.desktop",
    "productName": "TrustLoop",
    "afterSign": "scripts/afterSign.js",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false,
      "extendInfo": {
        "CFBundleIconName": "AppIcon"
      }
    },
    "protocols": [
      {
        "name": "TrustLoop OAuth",
        "schemes": [
          "trustloop"
        ]
      }
    ],
    "dmg": {
      "icon": "assets/icon.icns",
      "iconSize": 128,
      "window": {
        "width": 600,
        "height": 300
      },
      "contents": [
        {
          "x": 180,
          "y": 170
        },
        {
          "x": 480,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist/main/**/*",
      "src/renderer/**/*",
      "package.json",
      "!assets/**/*",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.map",
      "!node_modules/**/*.md",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/*.d.mts",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/README*",
      "!node_modules/**/.github/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/prisma/**",
      "!node_modules/@prisma/client/generator-build/**",
      "!node_modules/@aws-sdk/**/dist-es/**"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1021.0",
    "@aws/lambda-invoke-store": "^0.2.4",
    "@smithy/querystring-builder": "^4.2.12",
    "@smithy/querystring-parser": "^4.2.12",
    "@smithy/service-error-classification": "^4.2.12",
    "@smithy/util-buffer-from": "^4.2.2",
    "@smithy/util-config-provider": "^4.2.2",
    "@smithy/uuid": "^1.1.2",
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "chart.js": "^4.5.1",
    "dotenv": "^16.5.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pg-connection-string": "^2.12.0",
    "pg-pool": "^3.10.0",
    "pg-protocol": "^1.10.0",
    "pgpass": "^1.0.5",
    "stytch": "^13.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prisma": "7.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
