    "framer-motion": "^12.35.1",
    "gsap": "^3.14.2",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "prisma": "^6.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "server-only": "^0.0.1",
    "stytch": "^13.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
