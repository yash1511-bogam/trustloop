    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "execa": "^9.6.1",
    "gradient-string": "^3.0.0",
