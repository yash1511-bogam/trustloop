{
  "name": "trustloop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:full": "concurrently -k -n web,worker -c cyan,magenta \"npm run dev\" \"npm run worker\"",
    "build": "next build",
    "start": "next start",
    "start:local": "node scripts/start-local.mjs",
    "start:local:setup": "node scripts/start-local.mjs --setup-only",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx scripts/seed.ts",
    "worker": "tsx scripts/worker.ts",
    "worker:once": "tsx scripts/worker.ts --once",
    "localstack:init": "tsx scripts/init-localstack.ts"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1004.0",
    "@gsap/react": "^2.1.2",
