{
  "name": "trustloop",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "dev:full": "concurrently -k -n web,worker -c cyan,magenta \"pnpm run dev\" \"pnpm run worker\"",
    "build": "next build",
    "start": "next start",
    "start:local": "node scripts/start-local.mjs",
    "start:local:setup": "node scripts/start-local.mjs --setup-only",
    "lint": "eslint",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status",
    "prisma:pull:print": "prisma db pull --print",
    "db:seed": "tsx scripts/seed.ts",
    "worker": "tsx scripts/worker.ts",
    "worker:once": "tsx scripts/worker.ts --once",
    "billing:grace:once": "tsx scripts/process-billing-grace.ts",
    "video:studio": "remotion studio remotion/index.ts",
    "video:render:landing": "remotion render remotion/index.ts TrustLoopHowItWorks public/videos/trustloop-how-it-works.mp4 --codec=h264 --crf=20 --overwrite",
    "localstack:init": "tsx scripts/init-localstack.ts",
    "ai-keys:verify": "tsx scripts/verify-ai-keys.ts"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1004.0",
    "@gsap/react": "^2.1.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/mdx": "^2.0.13",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dodopayments": "^2.23.2",
    "framer-motion": "^12.35.1",
    "fumadocs-core": "^16.6.10",
    "fumadocs-mdx": "^14.2.9",
    "fumadocs-ui": "^16.6.10",
    "gsap": "^3.14.2",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "next": "16.1.6",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "server-only": "^0.0.1",
    "stytch": "^13.1.0",
    "twilio": "^5.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.434",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "execa": "^9.6.1",
    "gradient-string": "^3.0.0",
    "ora": "^9.3.0",
    "remotion": "^4.0.434",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
