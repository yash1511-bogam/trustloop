# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# Custom domain CNAME target (e.g. your CloudFront/ALB domain). Falls back to NEXT_PUBLIC_APP_URL hostname.
# CUSTOM_DOMAIN_CNAME_TARGET=d1234abcdef.cloudfront.net

# Logging
# LOG_LEVEL: debug | info | warn | error | fatal
# LOG_MODE: auto | file | console
#   - auto (default): file logging on long-running hosts, console-only on serverless runtimes
#   - file: always attempt /logs file streams plus stdout
#   - console: stdout/stderr only (recommended for Vercel/serverless)
LOG_LEVEL=info
LOG_MODE=auto

# Database (Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trustloop?schema=public"
# For managed/remote Postgres, prefer explicit SSL mode:
# DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=verify-full"
# Connection pool size (defaults to pg driver default; increase for production)
# DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379
# Optional split Redis settings (used if REDIS_URL is not provided)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Stytch (required for auth)
STYTCH_PROJECT_ID=project-test-xxxx
STYTCH_SECRET=secret-test-xxxx
STYTCH_PUBLIC_TOKEN=public-token-test-xxxx
STYTCH_ENV=test
STYTCH_OTP_EXPIRATION_MINUTES=5
STYTCH_SESSION_DURATION_MINUTES=1440
STYTCH_OAUTH_START_MODE=b2c
# STYTCH_OAUTH_GOOGLE_START_URL=https://test.stytch.com/v1/b2b/public/oauth/google/discovery/start?public_token=...
# STYTCH_OAUTH_GITHUB_START_URL=https://test.stytch.com/v1/b2b/public/oauth/github/discovery/start?public_token=...
# STYTCH_B2B_DISCOVERY_ORGANIZATION_ID=organization-test-xxxx

# Key encryption (required for AI provider key storage)
KEY_ENCRYPTION_SECRET=replace-with-random-long-string

# Optional onboarding demo AI fallback
TRUSTLOOP_SHARED_DEMO_AI_PROVIDER=OPENAI
TRUSTLOOP_SHARED_DEMO_AI_KEY=
TRUSTLOOP_SHARED_DEMO_AI_MODEL=

# Resend (required for operational emails)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="TrustLoop <trustloop@ticket.yashbogam.me>"

# Slack integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Twilio (P1 SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Dodo Payments billing
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENV=test_mode
DODO_PRODUCT_ID_STARTER=
DODO_PRODUCT_ID_PRO=
DODO_PRODUCT_ID_ENTERPRISE=
DODO_PRODUCT_ID_STARTER_ANNUAL=
DODO_PRODUCT_ID_PRO_ANNUAL=

# Automation security
AI_KEY_HEALTH_CRON_SECRET=
BILLING_AUTOMATION_CRON_SECRET=
REMINDER_ENQUEUE_CRON_SECRET=

# Web Push (PWA notifications)
VAPID_SUBJECT=mailto:alerts@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional explicit public key for frontend exposure (falls back to VAPID_PUBLIC_KEY)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# LocalStack / AWS-like local infra
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCOUNT_ID=000000000000
REMINDER_QUEUE_NAME=trustloop-incident-reminders
REMINDER_QUEUE_URL=http://localhost:4566/000000000000/trustloop-incident-reminders

# Automation settings
REMINDER_STALE_MINUTES=240

# Test / e2e helpers (never enable in production)
TRUSTLOOP_STUB_AUTH=0
TRUSTLOOP_STUB_OTP_CODE=000000
TRUSTLOOP_STUB_EMAIL_DELIVERY=0

# Optional seeding helper
SEED_STYTCH_USER_ID=stytch-demo-user

# Notes:
# - Keep real secrets in `.env` only.
# - `.env.example` is intentionally safe placeholder config.

# ── Sentry / Error Monitoring ─────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
