      "isDeleted": false,
      "boundElements": null,
      "updated": 1773474825406,
      "link": null,
      "locked": false,
      "text": "MESSAGES:\n  { workspaceId, incidentId, queuedAt, dueAt }\n  DelaySeconds: 0-900s for scheduling\nOPERATIONS:\n  enqueueReminder() → SendMessage\n  receiveReminderMessages() → long poll 10s\n  deleteReminderMessage() → ack after process\nTRACKING:\n  ReminderJobLog in PG (QUEUED/PROCESSED/FAILED)\nLOCAL DEV: LocalStack (docker-compose)",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "MESSAGES:\n  { workspaceId, incidentId, queuedAt, dueAt }\n  DelaySeconds: 0-900s for scheduling\nOPERATIONS:\n  enqueueReminder() → SendMessage\n  receiveReminderMessages() → long poll 10s\n  deleteReminderMessage() → ack after process\nTRACKING:\n  ReminderJobLog in PG (QUEUED/PROCESSED/FAILED)\nLOCAL DEV: LocalStack (docker-compose)",
      "autoResize": true,
      "lineHeight": 1.25
    },
