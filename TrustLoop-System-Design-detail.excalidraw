      "boundElements": null,
      "updated": 1773474825406,
      "link": null,
      "locked": false,
      "text": "STORES: User · Workspace · Incident · IncidentEvent\nAiProviderKey · WorkflowSetting · WorkspaceQuota\nWorkspaceSlaPolicy · WorkspaceDailyUsage · AuditLog\nWorkspaceBilling · BillingEventLog · WorkspaceApiKey\nWorkspaceInvite · StatusUpdate · CustomerUpdateDraft\nIncidentTag · PostMortem · PushSubscription\nStatusPageSubscriber · WorkspaceMembership\nINDEXES: tsvector full-text · (workspaceId,createdAt)\nComposite indexes · Cascade deletes · Unique constraints",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
