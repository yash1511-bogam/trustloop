      "link": null,
      "locked": false,
      "text": "P1 escalation: SMS to owner + on-call rotation (round-robin) + push notifications  |  Graceful shutdown (SIGTERM) + crash handler (unhandled rejection)",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "P1 escalation: SMS to owner + on-call rotation (round-robin) + push notifications  |  Graceful shutdown (SIGTERM) + crash handler (unhandled rejection)",
      "autoResize": true,
      "lineHeight": 1.25
    },
