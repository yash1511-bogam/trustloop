    {
      "id": "d6rdd",
      "type": "text",
      "x": 428,
      "y": 1545,
      "width": 2084.5,
      "height": 112.5,
      "angle": 0,
      "strokeColor": "#d9480f",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a0",
      "roundness": {
        "type": 3
      },
      "seed": 1015,
      "version": 2,
      "versionNonce": 1016,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773474825406,
      "link": null,
      "locked": false,
      "text": "CACHES:\n  session:auth:{sha256}  → AuthContext (TTL=session)\n  apikey:auth:{sha256}   → ApiKeyIdentity (TTL=30s)\n  plan-tier:{wsId}       → plan tier string (TTL=5min)\n  quota:{wsId}:{date}    → daily usage counters\n  exec:{wsId}            → executive dashboard data\nRATE LIMITS:\n  rl:{wsId}:{minuteBucket} → INCR + EXPIRE (atomic)\nFALLBACK: In-memory Map when Redis unavailable",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CACHES:\n  session:auth:{sha256}  → AuthContext (TTL=session)\n  apikey:auth:{sha256}   → ApiKeyIdentity (TTL=30s)\n  plan-tier:{wsId}       → plan tier string (TTL=5min)\n  quota:{wsId}:{date}    → daily usage counters\n  exec:{wsId}            → executive dashboard data\nRATE LIMITS:\n  rl:{wsId}:{minuteBucket} → INCR + EXPIRE (atomic)\nFALLBACK: In-memory Map when Redis unavailable",
      "autoResize": true,
      "lineHeight": 1.25
    },
