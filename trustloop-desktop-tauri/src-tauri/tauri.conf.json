{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "TrustLoop",
  "version": "0.10.0",
  "identifier": "ai.trustloop.desktop",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TrustLoop",
        "width": 1100,
        "height": 620,
        "minWidth": 960,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "decorations": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": [
      "../assets/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "frameworks": [],
      "entitlements": "../build/entitlements.mac.plist",
      "signingIdentity": null,
      "providerShortName": null,
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 600, "height": 300 }
      },
      "infoPlist": "Info.plist"
    },
    "category": "DeveloperTool",
    "shortDescription": "TrustLoop — Native macOS Desktop App",
    "longDescription": "Native macOS wrapper for TrustLoop incident management platform."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["trustloop"]
      }
    },
    "shell": {
      "open": true
    }
  }
}
